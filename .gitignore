#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# env file
.env

# Go
backend/tmp/
backend/*.exe
backend/vendor/

# Node / React
frontend/node_modules/
frontend/dist/
frontend/.env.local

# Docker
*.env

# OS
.DS_Store
Thumbs.db

# Editor/IDE
# .idea/
# .vscode/



# Frontend Dependencies
frontend/node_modules/
frontend/dist/
frontend/.env